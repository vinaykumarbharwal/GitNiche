# FastAPI Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# GitHub API Token (Optional but recommended to avoid rate limits)
GITHUB_TOKEN=your_github_personal_access_token_here

# Supabase Database Configuration
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key-here

# Upstash Redis Configuration
UPSTASH_REDIS_REST_URL=https://your-redis-instance-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token_here

# Hugging Face Inference API Configuration
HUGGINGFACE_API_KEY=your_huggingface_api_token_here
